# ============================================
# DoubleHub Web - 環境変数サンプル
# ============================================
#
# 実ファイルは .env.local にコピーして埋めること。
# service_role key は絶対にフロントには置かない（サーバー Route Handler 等でのみ利用）。
#
# ホスティングモード
# - static  : GitHub Pages 用（pnpm build:export）
# - dynamic : Cloudflare Pages 用（pnpm build, 認証あり）
NEXT_PUBLIC_HOSTING_MODE=static

# サイト公開 URL（OGP / sitemap 用）
NEXT_PUBLIC_SITE_URL=https://doublehub.jp

# GA4 測定 ID（既存継承）
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-DJW7K08F6F

# ==== Supabase: DoubleHub 本体 ====
# Project A
NEXT_PUBLIC_SUPABASE_DOUBLEHUB_URL=
NEXT_PUBLIC_SUPABASE_DOUBLEHUB_ANON_KEY=

# ==== Supabase: BookCompass ====
# Project B (njwakqmwcuoxqosjjwio)
NEXT_PUBLIC_SUPABASE_BOOKCOMPASS_URL=
NEXT_PUBLIC_SUPABASE_BOOKCOMPASS_ANON_KEY=

# ==== Supabase: TrainNote ====
# Project C (tvqvkvcqkigpmvzrmywl) - v1 では未使用だが初期化のみ行う
NEXT_PUBLIC_SUPABASE_TRAINNOTE_URL=
NEXT_PUBLIC_SUPABASE_TRAINNOTE_ANON_KEY=
